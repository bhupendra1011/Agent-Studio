# --- Mock / design mode (MSW intercepts same-origin Studio + Console v2 paths) ---
# NEXT_PUBLIC_MOCK_ENABLED=true
# MOCK_SSR_ORIGIN=http://127.0.0.1:3000

# Path segment after origin for Studio EN API (must match MSW + server mock)
# NEXT_PUBLIC_STUDIO_EN_PATH=/api/v1/studio/en

# Console API v2 path segment (projects list, create project)
# NEXT_PUBLIC_API_CONSOLE_V2_PATH=/api/v2

# --- Production / code mode (real backend) ---
# NEXT_PUBLIC_API_STUDIO_BASE_URL=https://your-gateway.example.com/api/v1/studio/en
# NEXT_PUBLIC_API_CONSOLE_V2_BASE_URL=https://your-gateway.example.com/api/v2

# Skip GET /studio/allowed-entries gate if your environment has no route yet
# NEXT_PUBLIC_SKIP_STUDIO_GATE=true

# NextAuth and other app secrets (see your deployment docs)
# AUTH_SECRET=
