# --- Mock mode (MSW intercepts same-origin Studio + Console v2 paths) ---
# NEXT_PUBLIC_MOCK_ENABLED=true
# MOCK_SSR_ORIGIN=http://127.0.0.1:3000

# Path segment after origin for Studio EN API (must match MSW + server mock)
# NEXT_PUBLIC_STUDIO_EN_PATH=/api/v1/studio/en

# Console API v2 path segment (projects list, create project)
# NEXT_PUBLIC_API_CONSOLE_V2_PATH=/api/v2

# --- Production / code mode (real backend) ---
# NEXT_PUBLIC_API_STUDIO_BASE_URL=https://your-gateway.example.com/api/v1/studio/en
# NEXT_PUBLIC_API_CONSOLE_V2_BASE_URL=https://your-gateway.example.com/api/v2

# Skip GET /studio/allowed-entries gate if your environment has no route yet
# NEXT_PUBLIC_SKIP_STUDIO_GATE=true

# Setup wizard: visiting /dashboard after login opens /dashboard/setup until you skip or finish
# for this browser session (sessionStorage). Logout or the login page resets that. Optional opt-out:
# NEXT_PUBLIC_SETUP_WIZARD_PROMPT_ON_DASHBOARD=false

# =============================================================================
# NextAuth (required for /dashboard — set AUTH_SECRET in production)
# =============================================================================
# AUTH_SECRET=                    # openssl rand -base64 32
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# Credentials provider (optional). If unset in development, defaults to demo/demo.
# AUTH_USERNAME=
# AUTH_PASSWORD=

# =============================================================================
# Admin portal (/dashboard/admin/*) — who gets role "admin"
# =============================================================================
# Comma-separated. Matched case-insensitively after trim.
# OAuth users: list emails that should see the Admin sidebar and /dashboard/admin routes.
# STUDIO_ADMIN_EMAILS=you@company.com,other@company.com
#
# Credentials (or any provider): list sign-in names or user ids (sub) that should be admin.
# STUDIO_ADMIN_USERNAMES=demo-admin
