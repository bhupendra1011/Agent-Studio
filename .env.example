# Required for production sessions (generate: openssl rand -base64 32)
AUTH_SECRET=

# OAuth — register redirect URLs with each provider:
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/github
# Docs: https://authjs.dev/getting-started/providers/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Credentials provider (optional; dev defaults to demo/demo if unset)
AUTH_USERNAME=
AUTH_PASSWORD=
